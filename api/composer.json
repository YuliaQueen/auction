{
    "name": "queen/app",
    "type": "project",
    "authors": [
        {
            "name": "queen"
        }
    ],
    "config": {
        "process-timeout": 0,
        "sort-packages": true
    },
    "require": {
        "php": "^7.4",
        "php-di/php-di": "^6.4",
        "slim/psr7": "^1.5",
        "slim/slim": "^4.10",
        "symfony/console": "^5.4"
    },
    "require-dev": {
        "overtrue/phplint": "^3.0",
        "roave/security-advisories": "dev-master",
        "squizlabs/php_codesniffer": "3.*",
        "vimeo/psalm": "4.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src"
        }
    },
    "scripts": {
        "lint": "phplint",
        "app": "php bin/app.php --ansi",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "psalm": "psalm"
    }
}
